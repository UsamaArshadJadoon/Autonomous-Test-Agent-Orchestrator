{
  "name": "autonomous-test-agent-orchestrator",
  "version": "1.0.0",
  "description": "Autonomous Test Agent Orchestrator - AI-powered test agent automation framework",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
