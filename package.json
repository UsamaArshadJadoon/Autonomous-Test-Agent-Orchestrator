    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.15.0",
    "commander": "^11.0.0",
    "axios": "^1.6.0",
    "pg": "^8.11.0",
    "playwright": "^1.40.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.0",
    "joi": "^17.11.0",
    "node-cache": "^5.1.2",
    "generic-pool": "^3.9.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  }
